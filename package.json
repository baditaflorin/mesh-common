{
  "name": "@baditaflorin/mesh-common",
  "version": "0.1.0",
  "description": "Shared scaffolding + runtime for baditaflorin/mesh-* rootless P2P apps. WebRTC mesh via Yjs, settings drawer, self-referential footer, clock sync, commit-reveal.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "files": ["src", "scaffold"],
  "bin": {
    "create-mesh-app": "./scaffold/create-mesh-app.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baditaflorin/mesh-common.git"
  },
  "author": "Florin Badita",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "y-webrtc": ">=10",
    "yjs": ">=13"
  },
  "engines": {
    "node": ">=22"
  }
}
