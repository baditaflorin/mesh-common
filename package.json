{
  "name": "@baditaflorin/mesh-common",
  "version": "0.1.0",
  "description": "Shared scaffolding + runtime for baditaflorin/mesh-* rootless P2P apps. WebRTC mesh via Yjs, settings drawer, self-referential footer, clock sync, commit-reveal.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css",
    "./testing": "./testing/index.ts"
  },
  "files": [
    "src",
    "testing",
    "scaffold",
    "scripts"
  ],
  "bin": {
    "create-mesh-app": "./scaffold/create-mesh-app.sh",
    "mesh-across": "./scripts/across.sh"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.0",
    "vitest": "^4.1.6",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.27"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baditaflorin/mesh-common.git"
  },
  "author": "Florin Badita",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "y-webrtc": ">=10",
    "yjs": ">=13"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "jsdom": "^29.1.1",
    "jsqr": "^1.4.0",
    "qrcode-generator": "^2.0.4"
  }
}
